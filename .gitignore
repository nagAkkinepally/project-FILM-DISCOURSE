# ===========================
# Film Discourse – .gitignore
# ===========================

# ──────────────────────────
# Frontend – Node / React
# ──────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/coverage/
frontend/.vite/

# ──────────────────────────
# Backend – Maven / Java
# ──────────────────────────
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.nar
!**/src/main/**/target/
!**/src/test/**/target/

# ──────────────────────────
# Spring / Application secrets
# ──────────────────────────
backend/src/main/resources/application-prod.yml
backend/src/main/resources/application-local.yml
*.env
.env

# ──────────────────────────
# IDE / Editors
# ──────────────────────────
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
.eclipse/
*.sts4-cache
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ──────────────────────────
# OS artefacts
# ──────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────
# Logs & temp files
# ──────────────────────────
*.log
logs/
*.tmp
*.bak
test-compile.txt

# ──────────────────────────
# Docker secrets
# ──────────────────────────
docker-compose.override.yml
